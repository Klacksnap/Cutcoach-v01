<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="theme-color" content="#07120d" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="apple-mobile-web-app-title" content="CutCoach" />
  <title>CutCoach</title>
  <link rel="manifest" href="manifest.json" />
  <link rel="apple-touch-icon" href="icons/icon-192.svg" />
  <link rel="stylesheet" href="styles.css" />
</head>
<body>
  <main class="app-shell">
    <header class="topbar">
      <div>
        <p class="eyebrow">CutCoach <span class="version-chip">v0.2 verified</span></p>
        <h1 id="greeting">Today</h1>
      </div>
      <button class="icon-button" id="themeToggle" type="button" aria-label="Toggle theme">☾</button>
    </header>

    <section id="screen-home" class="screen active" aria-labelledby="home-title">
      <div class="quick-row" aria-label="Quick actions">
        <button type="button" data-quick-tab="food">+ Food</button>
        <button type="button" data-quick-water="16">+16 oz</button>
        <button type="button" data-quick-tab="progress">Log weight</button>
      </div>

      <div class="hero-card">
        <div>
          <p class="muted">Current weight</p>
          <div class="hero-value"><span id="currentWeightText">208.8</span><small>lb</small></div>
          <p class="muted"><span id="lostText">35.0</span> lb lost • <span id="toGoalText">33.8</span> lb to goal</p>
        </div>
        <div class="goal-ring" aria-label="Goal progress">
          <svg viewBox="0 0 120 120" role="img">
            <circle cx="60" cy="60" r="50" class="ring-bg"></circle>
            <circle cx="60" cy="60" r="50" class="ring-fg" id="goalRing"></circle>
          </svg>
          <div class="ring-label"><strong id="goalPct">51%</strong><span>goal</span></div>
        </div>
      </div>

      <div class="metric-grid">
        <article class="metric-card">
          <div class="metric-label">Calories</div>
          <div class="metric-value"><span id="caloriesTotal">0</span><small>/ <span id="calorieGoalText">1700</span></small></div>
          <div class="progress"><span id="calorieBar"></span></div>
          <p id="calorieSub" class="metric-sub">1700 left</p>
        </article>
        <article class="metric-card">
          <div class="metric-label">Protein</div>
          <div class="metric-value"><span id="proteinTotal">0</span><small>g / <span id="proteinGoalText">160</span>g</small></div>
          <div class="progress"><span id="proteinBar"></span></div>
          <p id="proteinSub" class="metric-sub">160g left</p>
        </article>
        <article class="metric-card">
          <div class="metric-label">Water</div>
          <div class="metric-value"><span id="waterTotal">0</span><small>oz</small></div>
          <div class="stepper">
            <button type="button" data-water="8">+8</button>
            <button type="button" data-water="16">+16</button>
            <button type="button" id="waterReset">Reset</button>
          </div>
        </article>
        <article class="metric-card">
          <div class="metric-label">Steps</div>
          <div class="metric-value"><span id="stepsText">10000</span></div>
          <input id="stepsInput" class="mini-input" type="number" min="0" step="100" />
        </article>
      </div>

      <article class="coach-card">
        <div class="coach-head"><span>🤖</span><strong>Coach</strong></div>
        <p id="homeCoach">Log your meals and weight to get personalized guidance.</p>
      </article>
    </section>

    <section id="screen-food" class="screen" aria-labelledby="food-title">
      <div class="section-head">
        <h2 id="food-title">Food log</h2>
        <button class="primary small" id="copyYesterday" type="button">Copy yesterday</button>
      </div>

      <form class="panel" id="foodForm">
        <label>Food name<input id="foodName" required autocomplete="off" /></label>
        <div class="two-col">
          <label>Meal<select id="mealType"><option>Breakfast</option><option selected>Lunch</option><option>Dinner</option><option>Snack</option><option>Drinks</option></select></label>
          <label>Calories<input id="foodCal" type="number" inputmode="decimal" min="0" value="600" /></label>
        </div>
        <div class="four-col">
          <label>Protein<input id="foodProtein" type="number" inputmode="decimal" min="0" value="50" /></label>
          <label>Carbs<input id="foodCarbs" type="number" inputmode="decimal" min="0" value="45" /></label>
          <label>Fat<input id="foodFat" type="number" inputmode="decimal" min="0" value="15" /></label>
          <label>Servings<input id="foodServings" type="number" inputmode="decimal" min="0.1" step="0.1" value="1" /></label>
        </div>
        <div class="actions-row">
          <button class="primary" type="submit">+ Add food</button>
          <button class="secondary" id="saveMeal" type="button">Save meal</button>
        </div>
      </form>

      <div class="panel">
        <h3>Saved meals</h3>
        <div id="savedMeals" class="chip-list"></div>
      </div>

      <div class="panel">
        <h3>Today’s food</h3>
        <div id="foodList" class="list-empty">No food logged yet.</div>
      </div>
    </section>

    <section id="screen-progress" class="screen" aria-labelledby="progress-title">
      <div class="section-head"><h2 id="progress-title">Progress</h2></div>
      <div class="metric-grid">
        <article class="metric-card"><div class="metric-label">Goal date</div><div class="metric-value text"><span id="goalDateText">2026-10-01</span></div><p class="metric-sub">Your target</p></article>
        <article class="metric-card"><div class="metric-label">Needed pace</div><div class="metric-value"><span id="neededPace">0.0</span><small>lb/wk</small></div><p class="metric-sub" id="neededDeficit">0 cal/day</p></article>
        <article class="metric-card"><div class="metric-label">Projection</div><div class="metric-value text"><span id="projectionDate">—</span></div><p class="metric-sub">Based on settings</p></article>
        <article class="metric-card"><div class="metric-label">Logged days</div><div class="metric-value"><span id="loggedDays">0</span></div><p class="metric-sub">food or weight</p></article>
      </div>

      <form class="panel" id="weightForm">
        <h3>Log weight</h3>
        <div class="actions-row">
          <input id="weightInput" type="number" inputmode="decimal" step="0.1" placeholder="Weight" />
          <button class="primary" type="submit">Log</button>
        </div>
      </form>

      <div class="panel">
        <h3>Weight trend</h3>
        <canvas id="weightChart" width="360" height="160" aria-label="Weight chart"></canvas>
        <div id="weightList" class="compact-list"></div>
      </div>
    </section>

    <section id="screen-coach" class="screen" aria-labelledby="coach-title">
      <div class="section-head"><h2 id="coach-title">Digital coach</h2></div>
      <div id="coachNotes" class="coach-stack"></div>
      <div class="panel">
        <h3>Ask CutCoach</h3>
        <textarea id="coachQuestion" rows="4" placeholder="Example: Can I fit pizza tonight?"></textarea>
        <button class="primary full" id="askCoach" type="button">Get answer</button>
        <p id="coachAnswer" class="coach-answer">This version uses your local app data for simple coaching. We’ll add true AI later.</p>
      </div>
    </section>

    <section id="screen-more" class="screen" aria-labelledby="more-title">
      <div class="section-head"><h2 id="more-title">More</h2></div>
      <form class="panel" id="goalsForm">
        <h3>Goals</h3>
        <div class="two-col">
          <label>Calories<input id="goalCalories" type="number" min="0" /></label>
          <label>Protein<input id="goalProtein" type="number" min="0" /></label>
          <label>Carbs<input id="goalCarbs" type="number" min="0" /></label>
          <label>Fat<input id="goalFat" type="number" min="0" /></label>
          <label>Start weight<input id="startWeight" type="number" step="0.1" /></label>
          <label>Current weight<input id="settingsCurrentWeight" type="number" step="0.1" /></label>
          <label>Goal weight<input id="goalWeight" type="number" step="0.1" /></label>
          <label>Daily activity cal<input id="activityCalories" type="number" /></label>
        </div>
        <label>Goal date<input id="goalDate" type="date" /></label>
        <button class="primary full" type="submit">Save goals</button>
      </form>

      <div class="panel">
        <h3>Barcode lookup</h3>
        <p class="muted">Uses Open Food Facts when online. Camera barcode detection depends on browser support.</p>
        <div class="actions-row">
          <input id="barcodeInput" placeholder="UPC / barcode" inputmode="numeric" />
          <button class="secondary" id="lookupBarcode" type="button">Lookup</button>
        </div>
        <button class="primary full" id="startCamera" type="button">Start camera scanner</button>
        <video id="cameraPreview" class="camera" autoplay playsinline></video>
        <p id="barcodeMessage" class="muted small-text">Manual UPC entry always works as fallback.</p>
      </div>

      <div class="panel danger-zone">
        <h3>Data</h3>
        <button class="secondary" id="exportData" type="button">Export backup</button>
        <button class="danger" id="resetData" type="button">Reset app data</button>
      </div>
    </section>
  </main>

  <nav class="bottom-nav" aria-label="Main navigation">
    <button type="button" class="active" data-tab="home">🏠<span>Home</span></button>
    <button type="button" data-tab="food">🍗<span>Food</span></button>
    <button type="button" data-tab="progress">📈<span>Progress</span></button>
    <button type="button" data-tab="coach">🤖<span>Coach</span></button>
    <button type="button" data-tab="more">⚙️<span>More</span></button>
  </nav>

  <script src="app.js" defer></script>
</body>
</html>
